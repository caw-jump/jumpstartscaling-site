---
import BaseLayout from './BaseLayout.astro';
import Clarity from '../components/analytics/Clarity.astro';

interface Props {
  title: string;
  description: string;
  currentPath?: string;
}

const { title, description, currentPath } = Astro.props;
---

<BaseLayout title={title} description={description} fluid={true}>
  <slot name="head" slot="head" />
  
  <Clarity />
  
  <slot />
</BaseLayout>
