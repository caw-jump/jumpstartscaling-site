<div id="global-search-bar" class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[100] transform transition-all duration-700 hover:scale-105 active:scale-95 animate-float-in">
  <div class="relative group">
    <!-- Outer Glow -->
    <div class="absolute -inset-1 bg-gradient-to-r from-[#E8C677] to-[#C9A961] rounded-full blur-md opacity-25 group-hover:opacity-50 transition duration-500"></div>
    
    <a href="/search" class="relative flex items-center gap-3 bg-black/90 backdrop-blur-3xl border border-white/20 px-10 py-5 rounded-full text-white shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-all duration-300 group-hover:border-[#E8C677]/60">
      <div class="flex items-center justify-center w-8 h-8 rounded-full bg-[#E8C677] text-black shadow-lg shadow-[#E8C677]/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <span class="text-sm font-black uppercase tracking-[0.25em] whitespace-nowrap">Search Knowledge Vault</span>
      
      <button id="close-search-pill" type="button" class="ml-4 p-1 text-white/20 hover:text-red-400 transition-colors" aria-label="Dismiss Search Icon">
         <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </a>
  </div>
</div>

<script>
  const closeBtn = document.getElementById('close-search-pill');
  const searchBar = document.getElementById('global-search-bar');
  
  if (closeBtn && searchBar) {
    closeBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      searchBar.style.opacity = '0';
      searchBar.style.transform = 'translate(-50%, 40px) scale(0.9)';
      sessionStorage.setItem('search_hidden', 'true');
      setTimeout(() => searchBar.style.display = 'none', 400);
    });

    if (sessionStorage.getItem('search_hidden') === 'true') {
      searchBar.style.display = 'none';
    }
  }
</script>

<style>
  @keyframes float-in {
    0% { opacity: 0; transform: translate(-50%, 50px) scale(0.95); }
    100% { opacity: 1; transform: translate(-50%, 0) scale(1); }
  }
  .animate-float-in {
    animation: float-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
