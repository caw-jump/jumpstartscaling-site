---
import Layout from '../../layouts/BaseLayout.astro';
import { pseoContent } from '../../utils/pseo';

export async function getStaticPaths() {
  return pseoContent.map(entry => {
    const slugPath = entry.slug.replace(/^insights\//, '');
    return {
      params: { slug: slugPath },
      props: { entry }
    };
  });
}

const { entry } = Astro.props as { entry: any };

// Safely parse blocks
let blocks = [];
try {
  blocks = JSON.parse(entry.blocks);
} catch(e) {}

// Decoupled AST String Parser - Guarantees HTML DOM tags are never truncated
function renderMarkdown(str: string, isDark: boolean = false) {
    if (!str) return '';
    let res = str;
    let boldColor = isDark ? "text-black" : "text-white";
    
    // Bold parsing
    res = res.replace(/\*\*(.*?)\*\*/g, `<strong class="${boldColor} font-extrabold">$1</strong>`);
    
    // {variable} rendering with gold style and drop shadow
    res = res.replace(/\{([^}]+)\}/g, '<strong class="text-[#E8C677] font-black tracking-wide drop-shadow-[0_2px_2px_rgba(0,0,0,1)]">$1</strong>');
    
    return res;
}

// Global Array Deduplicator to drastically raise Uniqueness Scores from raw JSON dumps
function deduplicateItems(items: any[]) {
   if (!items || !Array.isArray(items)) return [];
   const seen = new Set();
   return items.filter(item => {
      const textProp = item.body || item.text || item.description || '';
      const titleProp = item.title || item.label || '';
      const hash = `${titleProp}|${textProp.substring(0, 30)}`.toLowerCase().replace(/[^a-z0-9]/g, '');
      if (!hash) return true; // keep empty ones
      if (seen.has(hash)) return false;
      seen.add(hash);
      return true;
   });
}

// Formats Block Content string sequences into HTML and strictly deduplicates massive repetitive AI strings
function smartBlockFormat(text: string, isDark: boolean = false) {
    if (!text) return '';
    let res = renderMarkdown(text, isDark);
    
    // Split text into paragraphs based on headings or standalone hashes or double newlines
    let paragraphs = res.split(/(?=###\s|##\s|#\s)|\n\n/);
    
    const uniqueParagraphs = [];
    const seenHashes = new Set();
    
    for (const p of paragraphs) {
        let clean = p.trim();
        if (!clean) continue;
        
        // Strip out the heading hashes exclusively for the deduplication check
        let hashText = clean.replace(/^(#{1,3})\s+/, '');
        
        // Normalize by removing EVERYTHING non-alphanumeric BEFORE grabbing the substring signature
        let hash = hashText.toLowerCase().replace(/[^a-z0-9]/g, '').substring(0, 35);
        
        if (hash && seenHashes.has(hash)) {
            continue; // Drop the exact matched chunk entirely
        }
        if (hash) seenHashes.add(hash);
        
        uniqueParagraphs.push(clean);
    }
    
    return uniqueParagraphs.map(clean => {
        // Match ## or ### headings
        let match = clean.match(/^(#{2,3})\s+(.*)$/s);
        if (match) {
            let level = match[1].length;
            let content = match[2];
            let Tag = `h${level}`;
            let classes = level === 2 
                ? (isDark ? 'text-3xl font-bold text-black mt-16 mb-8 uppercase tracking-wide border-b border-black/10 pb-4' : 'text-3xl font-bold text-white mt-16 mb-8 uppercase tracking-wide border-b border-white/10 pb-4')
                : (isDark ? 'text-2xl font-bold text-black mt-12 mb-6' : 'text-2xl font-bold text-[#E8C677] mt-12 mb-6');
            let pClasses = isDark ? "mt-4 mb-6 text-black/80 leading-relaxed text-lg" : "mt-4 mb-6 text-white/75 leading-relaxed text-lg";
            
            return smartHeading(content, Tag, classes, pClasses, isDark);
        }
        
        // If it was a stray single # or unformatted paragraph, strip the hash and render as text
        let fallbackText = clean.replace(/^#\s*/, '');
        let pClasses = isDark ? "mb-6 text-black/80 leading-relaxed text-lg" : "mb-6 text-white/75 leading-relaxed text-lg";
        return `<p class="${pClasses}">${fallbackText}</p>`;
    }).join('');
}

// Formats Headings into <Tag> + <P> safely (Handles up to 250 Char Limit and colon triggers statically)
function smartHeading(text: string, tag: string, classes: string, pClasses: string = "mt-4 mb-6 text-white/75 leading-relaxed text-lg", isDark: boolean = false) {
    if (!text) return '';
    
    // Clean rogue hashes from string boundaries
    let cleanText = text.replace(/^(### |## )/, '').replace(/( ###| ##)$/, '');

    let hText = cleanText;
    let pText = '';

    // SPLIT RULES PROCESSED ON RAW STRING PURELY
    let colonIdx = cleanText.indexOf(':');
    if (colonIdx !== -1 && colonIdx < 150) {
        hText = cleanText.substring(0, colonIdx + 1);
        pText = cleanText.substring(colonIdx + 1);
    } else if (cleanText.length > 250) {
        let pIdx = cleanText.indexOf('.', 250);
        if (pIdx !== -1) {
            hText = cleanText.substring(0, pIdx + 1);
            pText = cleanText.substring(pIdx + 1);
        }
    }

    // APPLY MARKDOWN ON ISOLATED HTML-SAFE ZONES
    let safeHText = renderMarkdown(hText.trim(), isDark);
    let safePText = pText ? renderMarkdown(pText.trim(), isDark) : '';

    let html = `<${tag} class="${classes}">${safeHText}</${tag}>`;
    if (safePText) {
        html += `\n<p class="${pClasses}">${safePText}</p>`;
    }
    return html;
}


---

<Layout title={entry.title} description={entry.excerpt}>
  <article class="pseo-generated-page">
    
    {blocks.map((block: any, index: number) => {
      const { block_type, data } = block;

      if (block_type === 'hero') {
        return (
          <section class="pt-32 pb-20 px-6 border-b border-white/5 relative overflow-hidden bg-[#0B0B0F]">
             <div class="absolute inset-0 bg-gradient-to-br from-[#E8C677]/10 via-transparent to-transparent opacity-50" />
             <div class="max-w-4xl mx-auto text-center relative z-10">
                {data.badge && <span class="inline-block px-4 py-1.5 rounded-full bg-[#E8C677]/10 text-[#E8C677] text-xs font-bold tracking-widest uppercase mb-6 border border-[#E8C677]/20" set:html={renderMarkdown(data.badge)} />}
                <Fragment set:html={smartHeading(data.headline, 'h1', 'text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight')} />
                <p class="text-xl text-white/70 mb-10" set:html={renderMarkdown(data.subhead)} />
                {data.cta_label && <a href={data.cta_href || "#audit"} class="inline-flex items-center justify-center px-8 py-4 bg-[#E8C677] text-black font-bold text-sm uppercase tracking-wider rounded-xl shadow-[0_0_30px_rgba(232,198,119,0.3)] hover:scale-105 transition-all" set:html={renderMarkdown(data.cta_label.replace('< ', '').replace(' />', ''))} />}
                {data.warning_text && <p class="mt-8 text-xs font-mono text-white/40 max-w-xl mx-auto" set:html={renderMarkdown(data.warning_text)} />}
             </div>
          </section>
        );
      }

      if (block_type === 'solution_cards') {
        return (
          <section class="py-24 px-6 bg-[#0B0B0F]">
            <div class="max-w-7xl mx-auto">
              <div class="text-center mb-16 max-w-3xl mx-auto">
                {data.eyebrow && <h4 class="text-sm font-bold text-[#E8C677] uppercase tracking-widest mb-4 flex items-center justify-center gap-2"><span class="w-8 h-px bg-[#E8C677]"></span> <span set:html={renderMarkdown(data.eyebrow.replace('// ', ''))} /> <span class="w-8 h-px bg-[#E8C677]"></span></h4>}
                <Fragment set:html={smartHeading(data.title, 'h2', 'text-3xl md:text-5xl font-bold text-white')} />
              </div>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                 {deduplicateItems(data.cards).map((card: any) => (
                   <div class="bg-white/5 border border-white/10 rounded-2xl p-8 hover:bg-white/10 transition-colors">
                      <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
                        <span class="w-1.5 h-6 bg-[#E8C677] rounded-full inline-block"></span>
                        <span set:html={renderMarkdown(card.title.replace('< ', '').replace(' />', ''))} />
                      </h3>
                      <p class="text-white/70 text-sm leading-relaxed" set:html={renderMarkdown(card.body)} />
                   </div>
                 ))}
              </div>
            </div>
          </section>
        )
      }

      if (block_type === 'icon_bullets') {
        return (
          <section class="py-24 px-6 border-y border-white/5 bg-black/40">
             <div class="max-w-7xl mx-auto">
                <Fragment set:html={smartHeading(data.title, 'h2', 'text-3xl md:text-4xl font-bold text-white mb-16 text-center max-w-4xl mx-auto')} />
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                   {deduplicateItems(data.bullets).map((bullet: any) => (
                     <div class="flex flex-col text-center items-center">
                        <div class="w-16 h-16 rounded-2xl bg-[#E8C677]/10 flex items-center justify-center text-[#E8C677] text-2xl font-bold mb-6 border border-[#E8C677]/20 shadow-[0_0_15px_rgba(232,198,119,0.15)]">
                          {bullet.icon}
                        </div>
                        <h3 class="text-xl font-bold text-white mb-4" set:html={renderMarkdown(bullet.title)} />
                        <p class="text-white/70 text-sm leading-relaxed" set:html={renderMarkdown(bullet.text)} />
                     </div>
                   ))}
                </div>
             </div>
          </section>
        )
      }

      if (block_type === 'value_prop') {
        return (
          <section class="py-24 px-6 bg-[#0B0B0F]">
            <div class="max-w-4xl mx-auto prose prose-invert prose-lg prose-p:text-white/75 prose-p:leading-relaxed prose-headings:text-white prose-a:text-[#E8C677] prose-headings:font-bold prose-h2:mt-12 prose-h3:mt-8">
              {data.title && <Fragment set:html={smartHeading(data.title, 'h2', 'text-3xl md:text-5xl font-bold text-white mb-10 text-center leading-tight')} />}
              <div set:html={smartBlockFormat(data.body)} />
            </div>
          </section>
        )
      }

      if (block_type === 'authority') {
        return (
          <section class="py-24 px-6 bg-gradient-to-br from-[#E8C677] to-[#B38D35] text-black">
            <div class="max-w-7xl mx-auto">
              <div class="grid grid-cols-1 gap-12 items-center">
                 <div class="prose prose-lg prose-p:text-black/80 prose-headings:text-black max-w-4xl mx-auto text-center">
                   <Fragment set:html={smartHeading(data.title, 'h2', 'text-3xl md:text-4xl font-extrabold mb-6 leading-tight text-black', 'mt-4 mb-6 text-black/80 leading-relaxed text-lg', true)} />
                   <div set:html={smartBlockFormat(data.body, true)} />
                 </div>
                 {data.stats && (
                   <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 bg-black/5 p-8 rounded-3xl backdrop-blur-sm border border-black/10">
                     {deduplicateItems(data.stats).map((stat: any) => (
                       <div class="bg-white/90 rounded-2xl p-6 text-center shadow-xl">
                         <div class="text-3xl md:text-4xl font-black mb-2 text-black" set:html={renderMarkdown(stat.value, true)} />
                         <div class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-black/60" set:html={renderMarkdown(stat.label, true)} />
                       </div>
                     ))}
                   </div>
                 )}
              </div>
            </div>
          </section>
        )
      }

      if (block_type === 'calculator') {
        return (
          <section class="py-24 px-6 bg-[#0B0B0F] border-y border-white/5">
            <div class="max-w-6xl mx-auto">
               <div class="text-center mb-16">
                 <Fragment set:html={smartHeading(data.section_title, 'h2', 'text-3xl md:text-4xl font-bold text-white mb-6')} />
                 <p class="text-lg text-white/70 max-w-3xl mx-auto" set:html={renderMarkdown(data.text)} />
               </div>
               
               <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                 {deduplicateItems(data.links).map((link: any) => (
                   <a href={link.href} class="group bg-white/5 border border-white/10 rounded-2xl p-8 hover:bg-white/10 transition-all flex flex-col justify-between h-full">
                      <div>
                        <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#E8C677] transition-colors" set:html={renderMarkdown(link.label)} />
                        <p class="text-sm text-white/60 leading-relaxed mb-6" set:html={renderMarkdown(link.description)} />
                      </div>
                      <div class="flex items-center text-[#E8C677] text-sm font-bold uppercase tracking-wider">
                         Access Tool 
                         <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                      </div>
                   </a>
                 ))}
               </div>
            </div>
          </section>
        )
      }
      
      if (block_type === 'audit_form') {
        return (
          <section id="audit" class="py-24 px-6 border-t border-white/5 bg-[#0B0B0F]">
            <div class="max-w-4xl mx-auto bg-white/5 border border-[#E8C677]/30 p-8 md:p-16 rounded-3xl text-center relative overflow-hidden">
               <div class="absolute inset-0 bg-gradient-to-br from-[#E8C677]/10 via-transparent to-transparent pointer-events-none" />
               <Fragment set:html={smartHeading(data.title, 'h2', 'text-3xl md:text-4xl font-bold text-white mb-6 relative z-10')} />
               <p class="text-white/70 mb-12 relative z-10 text-lg leading-relaxed" set:html={renderMarkdown(data.subhead)} />
               
               <div class="relative z-10 max-w-md mx-auto">
                 <div class="p-8 bg-[#050505] rounded-xl border border-white/10 text-left shadow-2xl">
                   <p class="text-xs text-white/50 mb-6 uppercase tracking-widest flex items-center gap-3">
                     <span class="w-2 h-2 rounded-full bg-[#E8C677] animate-pulse"></span> <span set:html={renderMarkdown(data.form_title.replace('_', ' '))} />
                   </p>
                   <input type="email" placeholder="Corporate Email Address" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-4 text-white mb-4 focus:outline-none focus:border-[#E8C677]/50 transition-colors" />
                   <button class="w-full bg-[#E8C677] text-black font-extrabold py-4 rounded-lg hover:bg-white transition-colors shadow-[0_0_20px_rgba(232,198,119,0.2)]">
                     <span set:html={renderMarkdown((data.submit_source?.includes('Audit') || data.submit_source === undefined) ? 'Start Free Audit' : 'Request Access')} />
                   </button>
                   <p class="text-[10px] text-center text-white/30 mt-4 uppercase">Secure SSL Process</p>
                 </div>
               </div>
            </div>
          </section>
        )
      }

      if (block_type === 'cta') {
        return (
          <section class="py-24 px-6 bg-gradient-to-br from-[#E8C677] to-[#C9A961] text-black text-center relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-white to-transparent" />
            <div class="max-w-4xl mx-auto relative z-10">
              <Fragment set:html={smartHeading(data.heading, 'h2', 'text-4xl md:text-5xl font-black mb-8 leading-tight text-black', 'mt-4 mb-6 text-black/80 leading-relaxed text-lg', true)} />
              <p class="text-xl md:text-2xl font-medium text-black/80 mb-12 leading-relaxed" set:html={renderMarkdown(data.text, true)} />
              <a href={data.href} class="inline-flex items-center justify-center px-12 py-5 bg-black text-white font-bold text-lg uppercase tracking-widest rounded-xl shadow-2xl hover:scale-105 hover:bg-black/80 transition-all">
                 <span set:html={renderMarkdown(data.label, true)} />
              </a>
            </div>
          </section>
        )
      }
      
      return null;
    })}

  </article>
<style is:global>
  h1 { font-size: 1.5rem !important; }
  h2 { font-size: 1.3rem !important; }
  h3 { font-size: 1.2rem !important; }
  p { font-size: 1em !important; }
  .container {
    width: 100% !important;
    margin: 0 auto !important;
    padding-left: 0rem !important;
    padding-right: 0rem !important;
    max-width: 100% !important;
  }
  @media (max-width: 750px) {
    .container {
      padding-left: 1.5rem !important;
      padding-right: 1.5rem !important;
    }
  }
</style>
</Layout>
