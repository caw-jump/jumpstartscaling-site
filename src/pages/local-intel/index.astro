---
import Layout from '../../layouts/BaseLayout.astro';
import { stateGroupedContent, top10States, STATE_NAME_MAP } from '../../utils/pseo';
import BubbleBadge from '../../components/ui/BubbleBadge.astro';

const allActiveStates = Object.keys(stateGroupedContent).sort();

// Provide a placeholder for truly "missing" states to ensure 50-state coverage
const ALL_50_STATES = Object.keys(STATE_NAME_MAP).sort();
const inactiveStates = ALL_50_STATES.filter(s => !allActiveStates.includes(s));
---

<Layout title="Local Intel Registry - Jumpstart Scaling" description="Explore data-driven growth insights, predictive modeling architectures, and private AI engineered solutions localized for your market.">
  <main class="pt-32 pb-40 bg-[#0B0B0F] min-h-screen">
    <div class="w-full max-w-7xl mx-auto px-6">
      
      <!-- Page Header -->
      <div class="mb-16 max-w-4xl text-center mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#C9A961]/10 border border-[#C9A961]/20 mb-6">
          <span class="w-2 h-2 rounded-full bg-[#C9A961] animate-pulse"></span>
          <BubbleBadge
            text="Geographic Growth Targeting"
            class="text-sm font-semibold text-[#C9A961] uppercase tracking-wider"
          />
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          National <span class="bg-gradient-to-r from-[#C9A961] to-[#C9A961]/50 bg-clip-text text-transparent">Local Intel</span> Registry
        </h1>
        <p class="text-xl text-white/70">
          Private AI automation architectures and intelligent revenue pipeline frameworks engineered for your specific local market constraints. Select your state below to access regional intelligence.
        </p>
      </div>

      <div class="mb-12 max-w-2xl mx-auto">
        <input
          id="state-search"
          type="text"
          placeholder="Search states..."
          class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-lg text-white focus:outline-none focus:border-[#C9A961]/60 transition-all placeholder:text-white/20"
        />
        <div id="state-search-meta" class="mt-3 text-xs font-mono text-white/40 uppercase tracking-widest text-center"></div>
      </div>

      <!-- Top 10 High Volume Markets -->
      <div class="mb-24">
         <h2 class="text-2xl font-bold text-white mb-8 border-b border-white/10 pb-4">High-Velocity Regional Data</h2>
         <div class="grid grid-cols-2 md:grid-cols-5 gap-4" id="top-states-grid">
            {top10States.map(state => {
              const count = stateGroupedContent[state]?.length || 0;
              const fullName = STATE_NAME_MAP[state] || state;
              return (
                <a href={`/local-intel/${state.toLowerCase()}`} data-state={fullName} class="state-link group relative bg-white/5 border border-white/10 rounded-xl p-8 text-center hover:bg-white/10 hover:border-[#C9A961]/50 transition-all duration-300">
                   <div class="absolute inset-0 bg-gradient-to-b from-[#C9A961]/10 to-transparent opacity-0 group-hover:opacity-100 rounded-xl transition-all" />
                   <h3 class="text-xl font-bold text-white group-hover:text-[#C9A961] transition-colors mb-2 uppercase tracking-widest relative z-10">{fullName}</h3>
                   <p class="text-xs font-medium text-white/50 relative z-10">{count} Frameworks</p>
                </a>
              );
            })}
         </div>
      </div>

      <div class="mb-24">
         <h2 class="text-2xl font-bold text-white mb-8 border-b border-white/10 pb-4">All Evaluated Markets</h2>
         <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-3" id="all-states-grid">
             {allActiveStates.map(state => (
                <a href={`/local-intel/${state.toLowerCase()}`} data-state={STATE_NAME_MAP[state] || state} class="state-link px-5 py-4 bg-white/5 rounded-xl border border-white/10 hover:border-[#C9A961]/50 hover:bg-[#C9A961]/10 text-white/80 hover:text-white transition-all text-sm font-semibold flex justify-between items-center group">
                   <span>{STATE_NAME_MAP[state] || state}</span>
                   <svg class="w-4 h-4 text-white/20 group-hover:text-[#C9A961] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                </a>
             ))}
         </div>
      </div>

      <!-- Coming Soon / Non-Indexed Markets -->
      <div>
         <h2 class="text-2xl font-bold text-white/30 mb-8 border-b border-white/5 pb-4">Expanding Coverage Map</h2>
         <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-2">
             {inactiveStates.map(state => (
                <div class="px-4 py-2 bg-white/[0.02] rounded-lg border border-white/[0.05] text-white/20 text-xs font-medium cursor-not-allowed">
                   {STATE_NAME_MAP[state]} <span class="text-[8px] opacity-50 block uppercase">Indexing...</span>
                </div>
             ))}
         </div>
      </div>

    </div>
  </main>

<script is:inline>
  const input = document.getElementById('state-search');
  const meta = document.getElementById('state-search-meta');
  const links = Array.from(document.querySelectorAll('a.state-link'));

  function apply() {
    const q = (input?.value || '').trim().toLowerCase();
    let shown = 0;
    for (const el of links) {
      const name = (el.getAttribute('data-state') || '').toLowerCase();
      const visible = q.length === 0 || name.includes(q);
      el.style.display = visible ? '' : 'none';
      if (visible) shown++;
    }
    if (meta) meta.textContent = q.length === 0 ? `${shown} states` : `${shown} matches`;
  }

  input?.addEventListener('input', apply);
  apply();
</script>
</Layout>
