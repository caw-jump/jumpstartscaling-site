---
import Layout from '../../../layouts/BaseLayout.astro';
import { stateGroupedContent, PseoEntry } from '../../../utils/pseo';

// Generate static paths via pagination
export async function getStaticPaths({ paginate }: any) {
  const allStates = Object.keys(stateGroupedContent);
  
  return allStates.flatMap(state => {
    const pagesForState = stateGroupedContent[state];
    return paginate(pagesForState, {
      params: { state: state.toLowerCase() },
      pageSize: 12, // User requested exactly 12 grid items per page
    });
  });
}

const { page } = Astro.props as { page: { data: PseoEntry[], url: { prev?: string, next?: string }, currentPage: number, lastPage: number } };
const { state } = Astro.params;
---

<Layout title={`Local Intel - ${state?.toUpperCase()}`} description={`Data driven growth insights and private AI architecture engineering for businesses executing in ${state?.toUpperCase()}.`}>
  <main class="pt-32 pb-24 bg-[#0B0B0F] min-h-screen">
    <div class="w-full max-w-7xl mx-auto px-6">
      
      <!-- Page Header -->
      <div class="mb-12">
        <a href="/local-intel" class="inline-flex items-center text-sm text-white/50 hover:text-accent transition-colors mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to National Intel Registry
        </a>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
          Local Intel Registry: <span class="bg-gradient-to-r from-[#E8C677] to-[#E8C677]/60 bg-clip-text text-transparent">{state?.toUpperCase()}</span>
        </h1>
        <p class="text-lg text-white/70 max-w-3xl">
          Explore customized revenue pipeline frameworks, intelligent CRM automations, and growth engineering playbooks localized specifically for high-growth enterprises within {state?.toUpperCase()}.
        </p>
      </div>

      <!-- Grid Layout: 3 col desktop, 1 col mobile -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {page.data.map((item) => (
          <a href={`/${item.slug}`} class="block group">
            <div class="h-full bg-white/5 border border-white/10 rounded-2xl p-8 hover:bg-white/10 transition-all duration-300 relative overflow-hidden flex flex-col">
              <div class="absolute inset-0 bg-gradient-to-br from-[#E8C677]/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
              
              <div class="mb-4">
                <span class="px-3 py-1 bg-[#E8C677]/20 text-[#E8C677] rounded-full text-xs font-semibold uppercase tracking-wider border border-[#E8C677]/30">
                  {item.category.replace(/-/g, ' ')}
                </span>
              </div>
              
              <h2 class="text-xl font-bold text-white mb-3 group-hover:text-[#E8C677] transition-colors leading-tight">
                {item.title}
              </h2>
              
              <div class="flex items-center gap-2 mb-4">
                 <span class="text-xs text-white/50 bg-black/40 px-2 py-1 rounded">Execution Layer</span>
                 <span class="text-xs text-white/50 bg-black/40 px-2 py-1 rounded">{item.city}, {item.state}</span>
              </div>

              <p class="text-sm text-white/70 line-clamp-3 mb-6 flex-grow">
                {item.headline || "Uncover advanced private AI strategies and CRM orchestration frameworks mapped directly to your operational focus."}
              </p>
              
              <div class="mt-auto flex items-center text-[#E8C677] text-sm font-semibold">
                Access the Playbook
                <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Pagination Controls -->
      {page.lastPage > 1 && (
        <div class="mt-16 flex items-center justify-center gap-4">
          {page.url.prev ? (
            <a href={page.url.prev} class="px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white hover:bg-[#E8C677] hover:text-black transition-colors font-medium">
              &larr; Previous
            </a>
          ) : (
            <span class="px-6 py-3 rounded-xl bg-white/5 border border-white/5 text-white/30 cursor-not-allowed">
              &larr; Previous
            </span>
          )}
          
          <span class="px-6 py-3 rounded-xl bg-[#E8C677]/10 border border-[#E8C677]/20 text-[#E8C677] font-medium">
            Page {page.currentPage} of {page.lastPage}
          </span>
          
          {page.url.next ? (
            <a href={page.url.next} class="px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white hover:bg-[#E8C677] hover:text-black transition-colors font-medium">
              Next &rarr;
            </a>
          ) : (
            <span class="px-6 py-3 rounded-xl bg-white/5 border border-white/5 text-white/30 cursor-not-allowed">
              Next &rarr;
            </span>
          )}
        </div>
      )}

    </div>
  </main>
<style is:global>
  h1 { font-size: 1.5rem !important; }
  h2 { font-size: 1.3rem !important; }
  h3 { font-size: 1.2rem !important; }
  p { font-size: 1em !important; }
  .container {
    width: 100% !important;
    margin: 0 auto !important;
    padding-left: 0rem !important;
    padding-right: 0rem !important;
    max-width: 100% !important;
  }
</style>
</Layout>
