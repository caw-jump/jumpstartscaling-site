---
import Layout from '../../../layouts/BaseLayout.astro';
import { stateGroupedContent, type PseoEntry } from '../../../utils/pseo';
import LocalIntelTile from '../../../components/ui/LocalIntelTile.astro';

// Generate static paths via pagination
export async function getStaticPaths({ paginate }: any) {
  const allStates = Object.keys(stateGroupedContent);
  
  return allStates.flatMap(state => {
    const pagesForState = stateGroupedContent[state];
    return paginate(pagesForState, {
      params: { state: state.toLowerCase() },
      pageSize: 12, // User requested exactly 12 grid items per page
    });
  });
}

const { page } = Astro.props as { page: { data: PseoEntry[], url: { prev?: string, next?: string }, currentPage: number, lastPage: number } };
const { state } = Astro.params;
---

<Layout title={`Local Intel - ${state?.toUpperCase()}`} description={`Data driven growth insights and private AI architecture engineering for businesses executing in ${state?.toUpperCase()}.`}>
  <main class="pt-32 pb-24 bg-[#0B0B0F] min-h-screen">
    <div class="w-full max-w-7xl mx-auto px-6">
      
      <!-- Page Header -->
      <div class="mb-12">
        <a href="/local-intel" class="inline-flex items-center text-sm text-white/50 hover:text-[#C9A961] transition-colors mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to National Intel Registry
        </a>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
          Local Intel Registry: <span class="bg-gradient-to-r from-[#C9A961] to-[#C9A961]/60 bg-clip-text text-transparent">{state?.toUpperCase()}</span>
        </h1>
        <p class="text-lg text-white/70 max-w-3xl">
          Explore customized revenue pipeline frameworks, intelligent CRM automations, and growth engineering playbooks localized specifically for high-growth enterprises within {state?.toUpperCase()}.
        </p>
      </div>

      <!-- Grid Layout: 2 col desktop, 1 col mobile -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {page.data.map((item, index) => (
          <LocalIntelTile
            title={item.title}
            description={item.headline || "Uncover advanced private AI strategies and CRM orchestration frameworks mapped directly to your operational focus."}
            href={`/${item.slug}`}
            category={item.category}
            city={item.city}
            state={item.state}
            index={index}
          />
        ))}
      </div>

      <!-- Pagination Controls -->
      {page.lastPage > 1 && (
        <div class="mt-16 flex items-center justify-center gap-4">
          {page.url.prev ? (
            <a href={page.url.prev} class="px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white hover:bg-[#C9A961] hover:text-black transition-colors font-medium">
              &larr; Previous
            </a>
          ) : (
            <span class="px-6 py-3 rounded-xl bg-white/5 border border-white/5 text-white/30 cursor-not-allowed">
              &larr; Previous
            </span>
          )}
          
          <span class="px-6 py-3 rounded-xl bg-[#C9A961]/10 border border-[#C9A961]/20 text-[#C9A961] font-medium">
            Page {page.currentPage} of {page.lastPage}
          </span>
          
          {page.url.next ? (
            <a href={page.url.next} class="px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white hover:bg-[#C9A961] hover:text-black transition-colors font-medium">
              Next &rarr;
            </a>
          ) : (
            <span class="px-6 py-3 rounded-xl bg-white/5 border border-white/5 text-white/30 cursor-not-allowed">
              Next &rarr;
            </span>
          )}
        </div>
      )}

    </div>
  </main>
</Layout>
