---
// src/pages/audit.astro - Updated high-conversion version
import BaseLayout from '../layouts/BaseLayout.astro';
import ScalingSurvey from '../components/interactivity/ScalingSurvey.tsx';

---

<BaseLayout 
  title="Free Moat Audit | Jumpstart Scaling" 
  description="60-second interactive quiz to score your growth defensibility and get a custom scaling roadmap." 
  palette="gold" 
  fluid={true}
>
  {/* Hero Section */}
  <section class="section dark relative">
    <div class="container max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter">
        Is Your Growth Built on a <br />
        <span class="gradient-text">House of Cards?</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/80 max-w-2xl mx-auto leading-relaxed">
        Most SaaS companies scale until they break. Identify the exact bottlenecks preventing you from reaching <span class="text-accent font-bold">$10M+ ARR</span>.
      </p>
      <p class="mt-6 text-accent font-mono text-sm tracking-widest uppercase">
        60-Second Assessment • Personal Roadmap • 100% Free
      </p>
    </div>
  </section>

  <section class="section dark">
    <div class="container max-w-6xl mx-auto px-6">
      {/* Value Prop Grid */}
      <div class="grid md:grid-cols-3 gap-8 text-center md:text-left">
        <div class="glass-card p-8 hover:-translate-y-2 transition duration-300">
            <div class="text-4xl mb-4">🔍</div>
            <h3 class="text-xl font-bold mb-2 text-white">Find Invisible Leaks</h3>
            <p class="text-white/60">Pinpoint where you're losing money in your acquisition funnel—from ad spend waste to churn.</p>
        </div>
        <div class="glass-card p-8 hover:-translate-y-2 transition duration-300">
            <div class="text-4xl mb-4">📊</div>
            <h3 class="text-xl font-bold mb-2 text-white">Benchmark Against Top 1%</h3>
            <p class="text-white/60">See how your metrics (CAC, LTV, Retention) stack up against 2025 SaaS leaders.</p>
        </div>
        <div class="glass-card p-8 hover:-translate-y-2 transition duration-300">
            <div class="text-4xl mb-4">🗺️</div>
            <h3 class="text-xl font-bold mb-2 text-white">Get a Custom Roadmap</h3>
            <p class="text-white/60">Receive a detailed, prioritized action plan tailored to your specific growth stage.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container max-w-4xl mx-auto px-6">
      <div id="audit-tool" class="scroll-mt-24">
         <ScalingSurvey client:load />
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container max-w-4xl mx-auto px-6 text-center border-t border-white/10 pt-16">
      <p class="text-sm text-white/40 uppercase tracking-widest mb-8">Trusted by founders scaling from $1M to $50M</p>
      <div class="flex flex-wrap justify-center gap-12 opacity-50 grayscale hover:grayscale-0 transition duration-500">
           {/* Simple text logos for now, or replace with SVGs if available */}
           <span class="text-xl font-bold font-serif">Acme Corp</span>
           <span class="text-xl font-bold font-mono">TechFlow</span>
           <span class="text-xl font-bold italic">ScaleUp</span>
           <span class="text-xl font-bold">VentureOne</span>
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container max-w-3xl mx-auto px-6 text-center">
        <h3 class="text-2xl font-bold mb-4">Why is this free?</h3>
        <p class="text-black/70 mb-8">
            We believe in value first. This audit gives you clarity. If you need help executing the roadmap, we hope you'll consider Jumpstart Scaling as your partner. If not, you still walk away with a winning strategy.
        </p>
        <p class="text-xs text-black/50">
          🔒 Your data is secure. We calculate your score locally and only use your email to send your report.
        </p>
    </div>
  </section>
</BaseLayout>
