---
import Layout from '../layouts/BaseLayout.astro';
import { STATE_NAME_MAP } from '../utils/pseo';

// This page renders primarily on the client to handle the 3,700+ page search 
// without server-side latency for every keystroke.
---

<Layout 
  title="Search High-Scale Playbooks" 
  description="Search across thousands of business automation playbooks and localized niche solutions."
>
  <div class="py-20 max-w-5xl mx-auto min-h-[70vh]">
    <div class="mb-12 border-b border-white/5 pb-12">
        <h1 class="text-4xl md:text-5xl font-black text-white mb-6 uppercase tracking-tighter">
            Knowledge <span class="text-[#E8C677]">Engine</span>
        </h1>
        <p class="text-white/60 text-lg max-w-2xl leading-relaxed">
            Query our entire database of over 3,700 high-intent programmatic playbooks. 
            Search by <strong class="text-white">city, state, or niche</strong> to find your specific solution.
        </p>
    </div>

    <!-- Live Search Container -->
    <div id="search-root" class="space-y-12">
        <div class="relative">
             <input 
                type="text" 
                id="advanced-search-input" 
                placeholder="Type to filter playbooks..." 
                class="w-full bg-white/5 border border-[#E8C677]/20 rounded-2xl px-8 py-6 text-2xl text-white focus:outline-none focus:border-[#E8C677] transition-all placeholder:text-white/10"
                autofocus
             />
             <div id="search-status" class="mt-4 text-xs font-mono text-[#E8C677]/50 uppercase tracking-widest flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#E8C677] animate-pulse"></span>
                Loading search index...
             </div>
        </div>

        <div id="results-count" class="text-sm font-bold text-white/40 uppercase tracking-widest hidden">
            Found <span id="count-num" class="text-white">0</span> matches
        </div>

        <div id="search-results" class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-24">
            <!-- Dynamic results injected here -->
            <div class="col-span-full py-12 text-center text-white/20 italic animate-pulse">
                Initializing engine...
            </div>
        </div>
    </div>
  </div>
</Layout>

<script define:vars={{ STATE_NAME_MAP }}>
    // Advanced Search Logic
    let searchIndex = [];
    const resultsContainer = document.getElementById('search-results');
    const input = document.getElementById('advanced-search-input');
    const status = document.getElementById('search-status');
    const countContainer = document.getElementById('results-count');
    const countNum = document.getElementById('count-num');

    async function initSearch() {
        try {
            const res = await fetch('/api/search.json');
            searchIndex = await res.json();
            
            // Set initial status
            status.innerHTML = `<span class="text-[#E8C677]">Online:</span> ${searchIndex.length.toLocaleString()} playbooks indexed`;
            
            // Check for initial URL param
            const params = new URLSearchParams(window.location.search);
            const query = params.get('q');
            if (query) {
                input.value = query;
                performSearch(query);
            } else {
                renderResults(searchIndex.slice(0, 10)); // Top 10 preview
            }
        } catch (e) {
            status.innerHTML = `<span class="text-red-500">Error:</span> Failed to load search index.`;
        }
    }

    function performSearch(query) {
        if (!query || query.trim().length < 2) {
            renderResults(searchIndex.slice(0, 10));
            countContainer.classList.add('hidden');
            return;
        }

        const q = query.toLowerCase().trim();
        const filtered = searchIndex.filter(item => {
            const fullName = STATE_NAME_MAP[item.state] || item.state;
            return (
                item.title.toLowerCase().includes(q) ||
                item.city.toLowerCase().includes(q) ||
                item.state.toLowerCase().includes(q) ||
                fullName.toLowerCase().includes(q) ||
                item.category.toLowerCase().includes(q) ||
                item.slug.toLowerCase().includes(q)
            );
        });

        countContainer.classList.remove('hidden');
        countNum.innerText = filtered.length;
        renderResults(filtered.slice(0, 50)); // Limit to 50 for performance
    }

    function renderResults(results) {
        if (results.length === 0) {
            resultsContainer.innerHTML = `
                <div class="col-span-full py-20 text-center border border-white/5 rounded-3xl bg-white/5">
                    <p class="text-white/40 text-lg">No playbooks found for that query.</p>
                    <button onclick="location.reload()" class="mt-4 text-[#E8C677] hover:underline font-bold uppercase text-xs">Reset Filters</button>
                </div>
            `;
            return;
        }

        resultsContainer.innerHTML = results.map(item => {
            const fullName = STATE_NAME_MAP[item.state] || item.state;
            return `
            <a href="/${item.slug}" class="group block p-8 bg-white/5 border border-white/10 rounded-2xl hover:bg-[#E8C677]/5 hover:border-[#E8C677]/30 transition-all">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-2 py-0.5 rounded bg-[#E8C677]/10 text-[#E8C677] text-[10px] font-bold uppercase tracking-widest border border-[#E8C677]/20">
                        ${item.category}
                    </span>
                    <span class="text-white/30 text-[10px] uppercase font-mono tracking-tighter">
                        ${item.city}, ${fullName}
                    </span>
                </div>
                <h3 class="text-xl font-bold text-white group-hover:text-[#E8C677] transition-colors leading-tight mb-3">
                    ${item.title}
                </h3>
                <p class="text-white/50 text-sm line-clamp-2">
                    ${item.headline}
                </p>
                <div class="mt-6 flex items-center text-[#E8C677] text-[10px] font-semibold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
                    View Blueprint <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 7l5 5m0 0l-5 5m5-5H6" stroke-width="3"/></svg>
                </div>
            </a>
        `}).join('');
    }

    // Input listener
    input?.addEventListener('input', (e) => {
        performSearch(e.target.value);
    });

    // Run init
    initSearch();
</script>
